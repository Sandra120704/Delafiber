<?php
namespace App\Controllers;

use App\Models\PersonaModel;
use App\Models\LeadModel;
use App\Models\CampanaModel;

class DashboardController extends BaseController
{
    public function index()
    {
        $personaModel = new PersonaModel();
        $leadModel    = new LeadModel();
        $campanaModel = new CampanaModel();

        $data['totalPersonas'] = count($personaModel->listarPersonasSP());
        $data['totalLeads']    = $leadModel->contarLeads();
        $data['totalCampanas'] = $campanaModel->contarCampanas();
        $data['leadsPorEstado'] = $leadModel->contarLeadsPorEstado();

        return view('dashboard', $data);
    }
}
